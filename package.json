{
  "name": "humanai",
  "version": "1.0.0",
  "description": "Human-like multi-platform auto reply assistant",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "express",
    "automation",
    "ai"
  ],
  "author": "Siva Krishnan",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.13",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "openai": "^6.45.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ignore": [
      "auth/**",
      "src/database/*.db",
      "humanai.db",
      "node_modules/**"
    ],
    "ext": "js,json"
  }
}